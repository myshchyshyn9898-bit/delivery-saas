# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# --- Server ---
PORT=8000

# --- Mapbox (for route map generation) ---
MAPBOX_TOKEN=your_mapbox_public_token

# --- App ---
BASE_URL=https://myshchyshyn9898-bit.github.io/delivery-saas
SUPER_ADMIN_IDS=6889016268

# --- Webhook Secrets (optional but highly recommended) ---
WHOP_WEBHOOK_SECRET=your_whop_webhook_secret_here
POSTER_WEBHOOK_SECRET=your_poster_webhook_secret_here
